# =============================================================================
# Cloudflare Pages プロジェクト - Terraform 設定
# =============================================================================

terraform {
  required_version = ">= 1.0"

  required_providers {
    cloudflare = {
      source  = "cloudflare/cloudflare"
      version = "~> 4.0"
    }
  }

{% if terraform_backend == "cloud" %}
  # Terraform Cloud backend
  # organization と workspaces を環境に合わせて設定してください
  cloud {
    organization = "{{ terraform_cloud_organization }}"
    workspaces {
      name = "{{ terraform_cloud_workspace }}"
    }
  }
{% elif terraform_backend == "s3" %}
  # S3 互換ストレージ backend（Cloudflare R2 等）
  # bucket, key, endpoint 等を環境に合わせて設定してください
  backend "s3" {
    bucket = "terraform-state"
    key    = "terraform.tfstate"
    region = "auto"

    # R2 の場合は以下も設定してください:
    # endpoint                    = "https://<account_id>.r2.cloudflarestorage.com"
    # access_key                  = var.r2_access_key_id
    # secret_key                  = var.r2_secret_access_key
    # skip_credentials_validation = true
    # skip_metadata_api_check     = true
    # skip_region_validation      = true
    # skip_requesting_account_id  = true
    # skip_s3_checksum            = true
  }
{% else %}
  # ⚠️ backend 未設定: state はローカルにのみ保存されます
  # CI 環境では state が失われるため、本番運用には不向きです
  # copier.yml の terraform_backend を "cloud" または "s3" に変更してください
{% endif %}
}

provider "cloudflare" {
  api_token = var.cloudflare_api_token
}

# -----------------------------------------------------------------------------
# Cloudflare Pages プロジェクト
# -----------------------------------------------------------------------------
resource "cloudflare_pages_project" "this" {
  account_id        = var.cloudflare_account_id
  name              = var.project_name
  production_branch = var.production_branch
}
